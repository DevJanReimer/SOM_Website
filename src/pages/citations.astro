<style>
  .container{
    padding-top: clamp(48px, 6vw, 80px);
    padding-bottom: clamp(64px, 10vw, 120px);
  }
  .ref-list{
    list-style:none;
    counter-reset: ref-counter;
    padding:0;
    margin:0;
    max-width:80ch;
  }
  .ref{
    counter-increment: ref-counter;
    position:relative;
    padding: 20px 0 20px 48px;
    border-bottom: 1px solid rgba(230,224,210,0.6);
    font-size: clamp(14px, 1.4vw, 15.5px);
    line-height: 1.75;
    color: var(--ink-soft);
    font-weight: 300;
  }
  .ref:last-child{ border-bottom: none; }
  .ref::before{
    counter(ref-counter);
    position:absolute;
    left:0;
    top:22px;
    font-family:'Cormorant Garamond',serif;
    font-size:22px;
    font-weight:400;
    color:rgba(230,224,210,0.9);
    line-height:1;
    min-width:36px;
  }
  .ref em{
    font-style:italic;
    color:var(--ink);
  }
  .ref a{
    color:var(--moss);
    word-break: break-all;
    transition: color 0.2s var(--ease-out);
  }
  .ref a:hover{ color: var(--moss-2); }
</style>
