---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import KpiStrip from '../components/KpiStrip.astro';
import Section from '../components/Section.astro';
import Formula from '../components/Formula.astro';

const kpis = [
  { label: 'Evaluation horizon', value: '25', unit: 'years', note: 'Full lifecycle analysis period' },
  { label: 'Optimization objectives', value: '2', unit: 'criteria', note: 'Maximize NPV · minimize CO₂' },
  { label: 'Weighting factor $w$', value: '0→1', unit: '', note: 'Emissions-only to NPV-only' },
  { label: 'Key outputs', value: '4', unit: 'metrics', note: 'NPV · payback · CO₂ abatement · PV/ST area' },
];

// Display math formulas ($$...$$)
const f = {
  objective: String.raw`$$\min Z = w \cdot \left(1 - \frac{\text{NPV}}{K_{\text{Baseline,Total}}}\right) + (1-w) \cdot \frac{E_{\text{Scenario,Total}}}{E_{\text{Baseline,Total}}}$$`,
  roofConstraint: String.raw`$$x + y \leq A_{\text{Limit}}$$`,
  nonNegativity: String.raw`$$x \geq 0, \quad y \geq 0$$`,
  stSizing: String.raw`$$y \cdot q_{\text{ST}} \leq Q_{\text{current}}$$`,
  budget: String.raw`$$\text{Inv}_{\text{PV}} \cdot x + \text{Inv}_{\text{ST}} \cdot y + K_{\text{Batt}} \leq \text{Budget}$$`,
  baselineCost: String.raw`$$K_{\text{Baseline},t} = S_{\text{current}} \cdot P_{\text{electricity},t} + Q_{\text{current}} \cdot P_{\text{heat},t} + F_{\text{electricity},t}$$`,
  baselineCostTotal: String.raw`$$K_{\text{Baseline,Total}} = \sum_{t=1}^{N} \frac{K_{\text{Baseline},t}}{(1+i)^t}$$`,
  baselineEmissions: String.raw`$$E_{\text{Baseline},t} = S_{\text{current}} \cdot EF_{\text{electricity}} + Q_{\text{current}} \cdot EF_{\text{heat}}$$`,
  baselineEmissionsTotal: String.raw`$$E_{\text{Baseline,Total}} = \sum_{t=1}^{N} E_{\text{Baseline},t}$$`,
  scenarioCost: String.raw`$$K_{\text{Scenario},t} = F_{\text{electricity},t} + S_{\text{res},t} \cdot P_{\text{electricity},t} + H_{\text{res},t} \cdot P_{\text{heat},t} + M_{\text{PV},t} \cdot x + M_{\text{ST},t} \cdot y - PV_{\text{export},t} \cdot P_{\text{feed-in},t}$$`,
  pvGen: String.raw`$$PV_t = x \cdot q_{\text{PV}} \cdot f_{\text{PV}}(t), \qquad f_{\text{PV}}(t) = \max\!\left(0,\; 1-(t-1)\cdot d_{\text{PV}}\right)$$
$$PV_{\text{self},t} = \min\!\left(PV_t \cdot sc(x,t),\; S_{\text{current}}\right)$$
$$PV_{\text{export},t} = \max\!\left(0,\; PV_t - PV_{\text{self},t}\right)$$
$$S_{\text{res},t} = \max\!\left(0,\; S_{\text{current}} - PV_{\text{self},t}\right)$$`,
  stGen: String.raw`$$ST_t = y \cdot q_{\text{ST}} \cdot f_{\text{ST}}(t), \qquad f_{\text{ST}}(t) = \max\!\left(0,\; 1-(t-1)\cdot d_{\text{ST}}\right)$$
$$ST_{\text{use},t} = ST_t \cdot u_{\text{ST}}(y,t)$$
$$H_{\text{res},t} = \max\!\left(0,\; Q_{\text{current}} - ST_{\text{use},t}\right)$$`,
  scenarioCostTotal: String.raw`$$K_{\text{Scenario,Total}} = I_0 + \sum_{t=1}^{N} \frac{K_{\text{Scenario},t}}{(1+i)^t}$$
$$I_0 = \text{Inv}_{\text{PV}} \cdot x + \text{Inv}_{\text{ST}} \cdot y + K_{\text{Batt}}$$`,
  scenarioEmissions: String.raw`$$E_{\text{Scenario},t} = S_{\text{res},t} \cdot EF_{\text{electricity}} + H_{\text{res},t} \cdot EF_{\text{heat}} + PV_t \cdot EF_{\text{PV}} + ST_t \cdot EF_{\text{ST}}$$`,
  scenarioEmissionsTotal: String.raw`$$E_{\text{Scenario,Total}} = \sum_{t=1}^{N} E_{\text{Scenario},t}$$`,
  pvSc: String.raw`$$sc(x,t) = \max\!\left(0,\; \min\!\left(1,\; 1 - (1-sc_{\text{Slider}})\cdot\frac{x}{A_{\text{Roof}}} + \text{Active}_{\text{Batt}}\cdot\min\!\left(0.5,\; \frac{\gamma \cdot q_{\text{PV}} \cdot B_{\text{estimate}} \cdot f_{\text{Batt}}(t)}{x}\right)\right)\right)$$`,
  battDeg: String.raw`$$f_{\text{Batt}}(t) = \max\!\left(0,\; 1-(t-1)\cdot d_{\text{Batt}}\right)$$`,
  battCap: String.raw`$$B_{\text{estimate}}(K_{\text{Batt}}) = \begin{cases} \dfrac{K_{\text{Batt}}}{847} & K_{\text{Batt}} < 16{,}940 \\[8pt] 20 + \dfrac{K_{\text{Batt}} - 16{,}940}{163.25} & 16{,}940 \leq K_{\text{Batt}} < 30{,}000 \\[8pt] 100 + \dfrac{K_{\text{Batt}} - 30{,}000}{266.67} & K_{\text{Batt}} \geq 30{,}000 \end{cases}$$`,
  stEffArea: String.raw`$$y_{\text{eff}}(t) = y \cdot f_{\text{ST}}(t)$$`,
  stUtil: String.raw`$$u_{\text{ST}}(y,t) = \max\!\left(u_{\min},\; \min\!\left(1,\; 1-(1-u_{\min})\cdot\frac{y_{\text{eff}}(t)-1}{A_{\text{Roof}}-1}\right)\right)$$`,
};

// Inline math labels for the variable explanation rows ($...$)
const v = {
  Z:          String.raw`$Z$`,
  w:          String.raw`$w$`,
  N:          String.raw`$N$`,
  NPV:        String.raw`$\text{NPV}$`,
  KBaseTotal: String.raw`$K_{\text{Baseline,Total}}$`,
  KScenTotal: String.raw`$K_{\text{Scenario,Total}}$`,
  EScenTotal: String.raw`$E_{\text{Scenario,Total}}$`,
  EBaseTotal: String.raw`$E_{\text{Baseline,Total}}$`,
  x:          String.raw`$x$`,
  y:          String.raw`$y$`,
  ALimit:     String.raw`$A_{\text{Limit}}$`,
  InvPV:      String.raw`$\text{Inv}_{\text{PV}}$`,
  InvST:      String.raw`$\text{Inv}_{\text{ST}}$`,
  KBatt:      String.raw`$K_{\text{Batt}}$`,
  Budget:     String.raw`$\text{Budget}$`,
  Scurrent:   String.raw`$S_{\text{current}}$`,
  Pelec:      String.raw`$P_{\text{electricity},t}$`,
  Qcurrent:   String.raw`$Q_{\text{current}}$`,
  Pheat:      String.raw`$P_{\text{heat},t}$`,
  Felec:      String.raw`$F_{\text{electricity},t}$`,
  i:          String.raw`$i$`,
  EFelec:     String.raw`$EF_{\text{electricity}}$`,
  EFheat:     String.raw`$EF_{\text{heat}}$`,
  KScent:     String.raw`$K_{\text{Scenario},t}$`,
  Sres:       String.raw`$S_{\text{res},t}$`,
  Hres:       String.raw`$H_{\text{res},t}$`,
  PVt:        String.raw`$PV_t$`,
  fPV:        String.raw`$f_{\text{PV}}(t)$`,
  PVself:     String.raw`$PV_{\text{self},t}$`,
  PVexport:   String.raw`$PV_{\text{export},t}$`,
  qPV:        String.raw`$q_{\text{PV}}$`,
  dPV:        String.raw`$d_{\text{PV}}$`,
  sc:         String.raw`$sc(x,t)$`,
  Pfeedin:    String.raw`$P_{\text{feed-in},t}$`,
  MPV:        String.raw`$M_{\text{PV},t}$`,
  MST:        String.raw`$M_{\text{ST},t}$`,
  STt:        String.raw`$ST_t$`,
  fST:        String.raw`$f_{\text{ST}}(t)$`,
  STuse:      String.raw`$ST_{\text{use},t}$`,
  qST:        String.raw`$q_{\text{ST}}$`,
  dST:        String.raw`$d_{\text{ST}}$`,
  uST:        String.raw`$u_{\text{ST}}(y,t)$`,
  I0:         String.raw`$I_0$`,
  EFPV:       String.raw`$EF_{\text{PV}}$`,
  EFST:       String.raw`$EF_{\text{ST}}$`,
  scSlider:   String.raw`$sc_{\text{Slider}}$`,
  fBatt:      String.raw`$f_{\text{Batt}}(t)$`,
  dBatt:      String.raw`$d_{\text{Batt}}$`,
  gamma:      String.raw`$\gamma$`,
  ActiveBatt: String.raw`$\text{Active}_{\text{Batt}}$`,
  Bestimate:  String.raw`$B_{\text{estimate}}$`,
  umin:       String.raw`$u_{\min}$`,
  ARoof:      String.raw`$A_{\text{Roof}}$`,
  yeff:       String.raw`$y_{\text{eff}}(t)$`,
};
---

<Base title="Chapter 6 · Carbon Reduction Calculator">

  <Hero
    eyebrow="Chapter 06"
    title="Carbon<br/>Reduction<br/>Calculator"
    subtitle="Built for municipalities exploring green energy investments before committing to them."
    image="/oberaegeri-zg.jpg"
    imageAlt="Oberägeri, Canton Zug"
  />

  <div class="container">
    <p class="lead reveal">
      Municipalities considering green energy investments face a common challenge: will the investment actually pay off, and how much CO₂ can realistically be reduced? This calculator was built to answer exactly that. It gives municipal decision-makers a tool to interactively experiment with rooftop photovoltaic (PV) and solar-thermal (ST) scenarios, before any decisions are made or installations are underway. The tool is interactive because each user can adjust the available roof area and energy prices, which the tool uses to calculate projected CO₂ savings, annual cost reduction, the payback period and the net present value for their specific building and budget.
    </p>
    <p class="lead-sub reveal">
      Our calculator can mathematically transform data from any Swiss town hall into an interactive what-if model. The sections below explain each step of the calculation.
    </p>
    <div class="lead-cta reveal">
      <a class="cta-btn" href="https://som-calculator.vercel.app" target="_blank" rel="noopener">Open calculator ↗</a>
    </div>

    <KpiStrip kpis={kpis} />
  </div>

  <Section chip="06 / A" label="A · Data Sources" title="Data Sources &amp; Methodology" id="s-6-a">
    <p>The calculator utilizes assumptions based on baseline consumption for a single municipality. For Oberägeri, the standard figures for electricity and heat demand are pre-loaded, and they come from audited consumption data and operational details provided via email correspondence with Alexander Klauz, administrative director of the Oberägeri municipality (Klauz, 2026). The data reflects the town hall's 2025 energy records, including the WWZ WasserSonneStrom tariff mix (80 % hydropower, 20 % PV) and the wood-chip district heating supply.</p>
    <p>The emission factors were drawn predominantly from KBOB (<em>Ökobilanzdaten im Baubereich</em> (2009/1:2022, version 8.02)), which is the Swiss federal reference dataset for life-cycle assessment in the building sector (KBOB, 2026). If a local supplier publishes its own verified figures, such as the WWZ WasserSonneStrom mix, these take precedence over the national averages. Every factor used in the model can be inspected and, if needed, overridden.</p>
  </Section>

  <Section chip="06 / B" label="B · Inputs" title="What You Enter" id="s-6-b">
    <p>The tool is built around a simple principle: the user only has to enter the data available to them. For example, electricity and heat consumption from a prior year, the utilized heating method, the utilized electricity mix, and the available roof area for a PV and ST upgrade.</p>
    <p>Optionally, the user can refine the financially relevant data points. For example, the user can adjust the model to reflect their actual electricity price and set an investment budget. When a budget is defined, the calculator uses it to calculate an optimized PV/ST split based on the financial constraints. Additionally, a weighting factor informs the model of the relative importance of CO₂ savings versus cost savings. Finally, the NPV calculation can be adjusted to include an inflation factor and the user can specify the rate of system degradation over time within a chosen depreciation period.</p>
    <div class="use-case-box reveal">
      <span class="use-case-label">Practical use case</span>
      <p>For municipalities that have already received a contractor quote during the budgeting phase, the quoted investment costs can be included in the calculator. The rates must be provided in square metres but when included they help calculate the financial viability of the quoted PV/ST split. The tool computes the NPV for each scenario and highlights whether a different allocation of roof area would deliver a better return or greater CO₂ reduction. The results and calculator can be used to challenge an offer, compare alternatives, or build the business case for your municipal council.</p>
    </div>
  </Section>

  <Section chip="06 / C" label="C · Expert settings" title="Defaults &amp; Expert Settings" id="s-6-c">
    <p>Using the calculator in its most user-friendly form requires no further data adjustments other than those listed above, as each default assumption has been set based on generalisable averages. For users that want more influence over the model there is an expert panel that allows them to adjust electricity and heat emission factors, installation cost rates, maintenance costs, specific energy yields, and embodied emissions of the solar panels. When not adjusted, the values are based predominantly on the KBOB dataset or published Swiss LCA sources (KBOB, 2026). The baseline estimates for the annual maintenance costs of PV and solar thermal rest on the operating cost figures published by EnergieSchweiz/BFE (2017) and the U.S. Department of Energy (n.d.). Edit them only if you have site-specific figures for example from a contractor's quote or a supplier's environmental product declaration.</p>
  </Section>

  <Section chip="06 / D" label="D · The Model" title="The Model" id="s-6-d">
    <p>The optimization model developed for the town hall is designed as a <strong>multi-criteria optimization problem</strong>. The goal of the solver is to determine the optimal system configuration and the ideal ratio between photovoltaic and solar thermal panels on the roof. The algorithm optimises a mathematical objective function composed of two competing primary objectives over a <strong>25-year time horizon</strong>: maximizing the net present value (NPV) and minimizing the building's total greenhouse gas emissions.</p>
    <p>To allow mathematical control of these objectives, the model includes a <strong>variable weighting factor</strong> $w$ ($0 \leq w \leq 1$) that determines whether the solver calculates a purely cost-optimized solution, a purely emissions-minimized solution, or a balanced compromise. The combined objective function $Z$ minimized by the solver is:</p>
    <Formula label="Objective function">
      <div set:html={f.objective}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.Z}></span>
        <span class="var-desc">Total value of the objective function minimized by the solver</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.w}></span>
        <span class="var-desc">Weighting factor, freely chosen (0 = emissions only, 1 = cost only)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.NPV}></span>
        <span class="var-desc">Financial value added over N years vs. the baseline: K<sub>Baseline,Total</sub> − K<sub>Scenario,Total</sub></span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.KBaseTotal}></span>
        <span class="var-desc">Total energy costs under current conditions (baseline) over N years</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.KScenTotal}></span>
        <span class="var-desc">Total energy costs of the scenario over N years (including initial investment)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.EScenTotal}></span>
        <span class="var-desc">Total CO₂eq emissions of the scenario over N years</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.EBaseTotal}></span>
        <span class="var-desc">Total CO₂eq emissions under current conditions (baseline) over N years</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.N}></span>
        <span class="var-desc">Number of years in the evaluation horizon (25 years)</span>
      </div>
    </div>
  </Section>

  <Section chip="06 / E" label="E · Variables" title="Decision Variables and Constraints" id="s-6-e">
    <p>The key decision variables in the model are the installed areas of the two solar technologies:</p>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.x}></span>
        <span class="var-desc">Area of the photovoltaic system (m²)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.y}></span>
        <span class="var-desc">Area of the solar thermal system (m²)</span>
      </div>
    </div>
    <p>The solver determines how much of the available roof area to allocate to each technology. Three constraints always apply:</p>
    <Formula label="Roof area constraint">
      <div set:html={f.roofConstraint}></div>
    </Formula>
    <Formula label="Non-negativity">
      <div set:html={f.nonNegativity}></div>
    </Formula>
    <Formula label="ST sizing limit prevents oversizing relative to heat demand">
      <div set:html={f.stSizing}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.ALimit}></span>
        <span class="var-desc">Maximum roof area available for installation (m²)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.qST}></span>
        <span class="var-desc">Specific annual solar thermal yield per m² (kWh/(m²·year))</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Qcurrent}></span>
        <span class="var-desc">Current annual heat demand of the town hall (kWh)</span>
      </div>
    </div>
    <p>All energy flows are additionally bounded between 0 and 1 so that no negative residual demands can arise. If the budget constraint is activated, the following also applies:</p>
    <Formula label="Budget constraint">
      <div set:html={f.budget}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.InvPV}></span>
        <span class="var-desc">Investment cost in CHF per m² of photovoltaic system</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.InvST}></span>
        <span class="var-desc">Investment cost in CHF per m² of solar thermal system</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.KBatt}></span>
        <span class="var-desc">Battery cost in CHF (only counted if battery option is enabled)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Budget}></span>
        <span class="var-desc">Maximum total investment budget in CHF</span>
      </div>
    </div>
    <p>In this case, the sum of the PV investment, solar thermal investment, and optional battery costs must not exceed the specified budget. Battery costs are only taken into account if the battery option is enabled.</p>
  </Section>

  <Section chip="06 / F" label="F · Baseline" title="Baseline Functions" id="s-6-f">
    <p>The baseline functions describe the reference state of the town hall without any additional PV or solar thermal systems. They serve as the comparison basis for the economic and environmental assessment of optimized scenarios, accounting for current electricity and heat demand, the respective energy prices, and associated emission factors.</p>
    <p>The annual baseline cost in year <em>t</em> is:</p>
    <Formula label="Annual baseline cost">
      <div set:html={f.baselineCost}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.Scurrent}></span>
        <span class="var-desc">Current annual electricity consumption (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Pelec}></span>
        <span class="var-desc">Electricity price in CHF/kWh in year t</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Qcurrent}></span>
        <span class="var-desc">Current annual heat consumption (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Pheat}></span>
        <span class="var-desc">Heat price in CHF/kWh in year t</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Felec}></span>
        <span class="var-desc">Fixed electricity charges in CHF in year t</span>
      </div>
    </div>
    <p>The present value of total baseline costs over the full project duration:</p>
    <Formula label="Total present value of baseline costs">
      <div set:html={f.baselineCostTotal}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.i}></span>
        <span class="var-desc">Discount factor</span>
      </div>
    </div>
    <p>Annual baseline emissions:</p>
    <Formula label="Annual baseline emissions">
      <div set:html={f.baselineEmissions}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.EFelec}></span>
        <span class="var-desc">Electricity emission factor (kg CO₂/kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.EFheat}></span>
        <span class="var-desc">Heat emission factor (kg CO₂/kWh)</span>
      </div>
    </div>
    <p>Cumulative baseline emissions over the full evaluation period:</p>
    <Formula label="Cumulative baseline emissions">
      <div set:html={f.baselineEmissionsTotal}></div>
    </Formula>
  </Section>

  <Section chip="06 / G" label="G · Scenario" title="Scenario Functions" id="s-6-g">
    <p>The scenario functions describe the situation after the new systems have been installed. They calculate the remaining electricity and heat demand after self-generation via PV and solar thermal systems, and additionally account for feed-in revenues, maintenance costs, system emissions, and where applicable battery effects. This allows the model to determine the extent to which costs and emissions change compared to the baseline.</p>
    <p>Annual scenario cost in year <em>t</em>:</p>
    <Formula label="Annual scenario cost">
      <div set:html={f.scenarioCost}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.KScent}></span>
        <span class="var-desc">Annual scenario cost in CHF in year t</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Felec}></span>
        <span class="var-desc">Fixed electricity charges in CHF in year t</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Sres}></span>
        <span class="var-desc">Residual grid electricity demand in year t (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Hres}></span>
        <span class="var-desc">Residual heat demand in year t (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.MPV}></span>
        <span class="var-desc">PV maintenance cost in CHF/m² per year</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.MST}></span>
        <span class="var-desc">ST maintenance cost in CHF/m² per year</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.PVexport}></span>
        <span class="var-desc">PV electricity exported to the grid in year t (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Pfeedin}></span>
        <span class="var-desc">Feed-in tariff for exported PV electricity in CHF/kWh in year t</span>
      </div>
    </div>
    <p>PV generation, self-consumption, and residual grid demand:</p>
    <Formula label="PV generation">
      <div set:html={f.pvGen}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.PVt}></span>
        <span class="var-desc">Total PV electricity generated in year t (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.qPV}></span>
        <span class="var-desc">Specific annual PV yield (kWh/(m²·year))</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.fPV}></span>
        <span class="var-desc">Annual PV yield factor, accounting for degradation: $\max(0,\; 1-(t-1) \cdot d_&#123;\text&#123;PV&#125;&#125;)$</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.dPV}></span>
        <span class="var-desc">Annual PV degradation rate</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.PVself}></span>
        <span class="var-desc">PV electricity used on-site for self-consumption in year t (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.sc}></span>
        <span class="var-desc">Effective self-consumption share in year $t$ (see <a href="#s-6-j">section J</a>)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.PVexport}></span>
        <span class="var-desc">PV electricity exported to the grid in year t (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Sres}></span>
        <span class="var-desc">Residual grid electricity demand after self-consumption in year t (kWh)</span>
      </div>
    </div>
    <p>Solar thermal generation, usable heat, and residual heat demand:</p>
    <Formula label="Solar thermal generation">
      <div set:html={f.stGen}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.STt}></span>
        <span class="var-desc">Total solar thermal heat generated in year t (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.qST}></span>
        <span class="var-desc">Specific annual ST yield (kWh/(m²·year))</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.fST}></span>
        <span class="var-desc">Annual ST yield factor, accounting for degradation: $\max(0,\; 1-(t-1) \cdot d_&#123;\text&#123;ST&#125;&#125;)$</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.dST}></span>
        <span class="var-desc">Annual ST degradation rate</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.STuse}></span>
        <span class="var-desc">Usable solar thermal heat in year t (kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.uST}></span>
        <span class="var-desc">ST utilization factor in year $t$ (see <a href="#s-6-j">section J</a>)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Hres}></span>
        <span class="var-desc">Residual heat demand after solar thermal in year t (kWh)</span>
      </div>
    </div>
    <p>Total scenario cost (present value) including initial investment $I_0$:</p>
    <Formula label="Total scenario cost (present value)">
      <div set:html={f.scenarioCostTotal}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.KScenTotal}></span>
        <span class="var-desc">Total scenario cost in CHF over N years (present value)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.I0}></span>
        <span class="var-desc">Initial investment at project start</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.i}></span>
        <span class="var-desc">Discount factor</span>
      </div>
    </div>
    <p>Annual scenario emissions:</p>
    <Formula label="Annual scenario emissions">
      <div set:html={f.scenarioEmissions}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.EFPV}></span>
        <span class="var-desc">Lifecycle emission factor of PV generation (kg CO₂/kWh)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.EFST}></span>
        <span class="var-desc">Lifecycle emission factor of ST generation (kg CO₂/kWh)</span>
      </div>
    </div>
    <p>Cumulative scenario emissions:</p>
    <Formula label="Cumulative scenario emissions">
      <div set:html={f.scenarioEmissionsTotal}></div>
    </Formula>
  </Section>

  <Section chip="06 / H" label="H · Inflation" title="Inflation Assumption" id="s-6-h">
    <p>An annual inflation factor can be enabled in the model. If activated, annual costs such as electricity prices, heating prices, fixed electricity charges, and maintenance costs increase each year by the specified percentage. The <strong>feed-in tariff remains constant</strong>, as it is assumed to be contractually fixed with the grid operator. Initial investments are also not adjusted for inflation, as they are incurred at the start of the project.</p>
  </Section>

  <Section chip="06 / I" label="I · Utilisation" title="Utilisation Rates and Self-Consumption" id="s-6-i">
    <p>For photovoltaic systems, not all generated electricity can be used directly in the town hall. The <strong>self-consumption rate</strong> $sc(x,t)$ describes what proportion of PV output in year $t$ is used on-site. As PV area increases, this proportion tends to decrease because production more often exceeds current electricity demand. If a battery is activated, the self-consumption share can increase, as part of the excess PV electricity can be temporarily stored and used later. The value is bounded between 0 and 1.</p>
    <p>For solar thermal energy, not all generated heat can be fully utilized. The <strong>utilization factor</strong> $u_&#123;\text&#123;ST&#125;&#125;(y,t)$ describes the proportion of solar thermal production that can actually meet heat demand. For small solar thermal areas, a high utilization rate is assumed; for larger areas, the usable portion decreases because more heat is produced than can be directly used or stored. This factor is also bounded between 0 and 1.</p>
    <p>These dynamic rates are essential for the validity of the optimization model. Without them, the solver would assume an unrealistic, linear scalability of yields and would theoretically completely over-engineer the town hall roof with solar components, since mathematically every additional square metre would also generate a proportional benefit in the objective function. The degressively decreasing factors specifically model the real-world phenomenon of temporary surplus production. As a result, the model must balance the economic and ecological marginal costs of an additional unit of area against the decreasing marginal benefit. This supports a practical, demand-oriented sizing of the systems and reduces the risk of over-sizing in the simulated energy system.</p>
  </Section>

  <Section chip="06 / J" label="J · Formal" title="Formal Representation of Utilisation Rates" id="s-6-j">
    <p>For photovoltaics, the self-consumption rate $sc(x,t)$ is modeled as an area-dependent function. $sc_&#123;\text&#123;Slider&#125;&#125;$ is the reference self-consumption rate assumed when the PV system covers the entire available roof area $A_&#123;\text&#123;Roof&#125;&#125;$. When the battery option is activated, the dummy variable $\text&#123;Active&#125;_&#123;\text&#123;Batt&#125;&#125;$ jumps from 0 to 1:</p>
    <Formula label="PV self-consumption rate">
      <div set:html={f.pvSc}></div>
    </Formula>
    <p>The remaining usable battery capacity in year t is described by the degradation factor:</p>
    <Formula label="Battery degradation factor">
      <div set:html={f.battDeg}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.scSlider}></span>
        <span class="var-desc">Reference self-consumption rate when the full roof area $A_&#123;\text&#123;Roof&#125;&#125;$ is covered by PV</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.ARoof}></span>
        <span class="var-desc">Total available roof area (m²)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.ActiveBatt}></span>
        <span class="var-desc">Battery activation dummy (0 = off, 1 = on)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.gamma}></span>
        <span class="var-desc">Calibration factor for battery effect on self-consumption (0 – 1)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.Bestimate}></span>
        <span class="var-desc">Estimated battery storage capacity in kWh (derived from $K_&#123;\text&#123;Batt&#125;&#125;$)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.fBatt}></span>
        <span class="var-desc">Battery degradation factor in year t (usable share of original capacity)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.dBatt}></span>
        <span class="var-desc">Battery annual degradation rate (% capacity lost per year)</span>
      </div>
    </div>
    <p>The estimated battery capacity $B_&#123;\text&#123;estimate&#125;&#125;$ is derived from the battery cost entered, using a piecewise cost-to-capacity function:</p>
    <Formula label="Battery capacity estimate (piecewise)">
      <div set:html={f.battCap}></div>
    </Formula>
    <p>The variable $B_&#123;\text&#123;estimate&#125;&#125;$ describes the storage capacity derived from battery costs. A larger storage capacity allows for the storage of additional PV surplus, thereby increasing the proportion of self-consumption from the photovoltaic system.</p>
    <p>$\gamma$ is a calibration factor for the battery effect. It determines the extent to which an existing battery increases PV self-consumption in the model. A low value means that the battery has only a small additional effect on self-consumption. A high value means that the battery contributes more significantly to storing excess PV electricity for later use. $\gamma$ can take values between 0 and 1.</p>
    <p>For solar thermal systems, the utilization factor $u_&#123;\text&#123;ST&#125;&#125;(y,t)$ is modeled as an area-dependent function. $u_&#123;\min&#125;$ is the minimum utilization rate when the full roof area $A_&#123;\text&#123;Roof&#125;&#125;$ is used for solar thermal. First, the effective ST area in year $t$ (accounting for degradation) is calculated:</p>
    <Formula label="Effective ST area">
      <div set:html={f.stEffArea}></div>
    </Formula>
    <p>The solar thermal utilization factor then follows:</p>
    <Formula label="ST utilization factor">
      <div set:html={f.stUtil}></div>
    </Formula>
    <div class="var-list">
      <div class="var-row">
        <span class="var" set:html={v.umin}></span>
        <span class="var-desc">Minimum utilization rate assumed when the full roof area is used for ST</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.yeff}></span>
        <span class="var-desc">Effective ST area in year t after degradation (m²)</span>
      </div>
      <div class="var-row">
        <span class="var" set:html={v.ARoof}></span>
        <span class="var-desc">Total available roof area (m²)</span>
      </div>
    </div>
    <p>For a solar thermal area of 1 m², a full utilization rate of 100 % is assumed. As the effective area grows, the factor decreases gradually until it reaches $u_&#123;\min&#125;$, reflecting the fact that larger systems more frequently generate excess heat that cannot be fully utilized.</p>
  </Section>

