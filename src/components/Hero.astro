---
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  authors?: string;
}
const { eyebrow, title, subtitle, image, imageAlt = '', authors } = Astro.props;
---

{image ? (
  <section class="hero hero--fullbleed">
    <div class="hero-bg">
      <img src={image} alt={imageAlt} loading="eager" class="hero-bg-img" id="hero-img" />
      <div class="hero-overlay" aria-hidden="true"></div>
    </div>
    <div class="container hero-content">
      <div class="eyebrow reveal">{eyebrow}</div>
      <h1 class="serif reveal reveal-delay-1" set:html={title}></h1>
      {subtitle && <div class="sub reveal reveal-delay-2">{subtitle}</div>}
      {authors && <div class="authors reveal reveal-delay-3">{authors}</div>}
      <a href="#chapter-1" class="scroll-cue reveal reveal-delay-4" aria-label="Scroll down">
        <span class="scroll-line"></span>
      </a>
    </div>
  </section>
) : (
  <section class="hero">
    <div class="container">
      <div class="eyebrow reveal">{eyebrow}</div>
      <h1 class="serif reveal reveal-delay-1" set:html={title}></h1>
      {subtitle && <div class="sub reveal reveal-delay-2">{subtitle}</div>}
      {authors && <div class="authors reveal reveal-delay-3">{authors}</div>}
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>
)}

<style>
  /* ── Text-only hero ── */
  .hero:not(.hero--fullbleed){
    position:relative;
    padding:clamp(72px, 12vw, 140px) 0 clamp(48px, 8vw, 80px);
    overflow:hidden;
  }
  .hero-glow{
    position:absolute;
    top:-200px;right:-200px;
    width:600px;height:600px;
    border-radius:50%;
    background:radial-gradient(circle, rgba(94,125,99,0.15) 0%, transparent 70%);
    pointer-events:none;z-index:-1;
    animation:drift 18s var(--ease-in-out) infinite alternate;
  }
  @keyframes drift{
    from{transform:translate(0,0) scale(1)}
    to{transform:translate(-40px,30px) scale(1.1)}
  }

  /* ── Full-bleed image hero ── */
  .hero--fullbleed{
    position:relative;
    min-height:92vh;
    display:flex;
    align-items:flex-end;
    overflow:hidden;
  }
  .hero-bg{
    position:absolute;
    inset:0;
  }
  .hero-bg-img{
    width:100%;
    height:100%;
    object-fit:cover;
    object-position:center 30%;
    transform:scale(1.04);
    transition:transform 0.1s linear;
    will-change:transform;
  }
  .hero-overlay{
    position:absolute;
    inset:0;
    background:
      linear-gradient(to top, rgba(26,34,38,0.88) 0%, rgba(26,34,38,0.5) 45%, rgba(26,34,38,0.15) 100%),
      linear-gradient(to right, rgba(26,34,38,0.4) 0%, transparent 60%);
  }
  .hero-content{
    position:relative;
    z-index:2;
    padding-bottom:clamp(56px, 8vw, 96px);
    padding-top:clamp(120px, 16vw, 180px);
  }
  .hero--fullbleed .eyebrow{
    font-size:12px;
    letter-spacing:.32em;
    text-transform:uppercase;
    color:rgba(217,166,121,0.9);
    font-weight:500;
    margin-bottom:24px;
  }
  .hero--fullbleed h1{
    font-size:clamp(44px, 7.5vw, 100px);
    line-height:1.02;
    font-weight:400;
    margin:0;
    letter-spacing:-0.025em;
    color:#fff;
    max-width:16ch;
    text-shadow:0 2px 40px rgba(26,34,38,0.3);
  }
  .hero--fullbleed h1 em{
    color:rgba(217,166,121,0.95);
    font-style:italic;
  }
  .hero--fullbleed .sub{
    margin-top:28px;
    font-size:14px;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:rgba(255,255,255,0.6);
    font-weight:300;
    max-width:52ch;
    line-height:1.7;
  }
  .authors{
    margin-top:36px;
    padding-top:24px;
    border-top:1px solid rgba(255,255,255,0.18);
    font-size:11px;
    letter-spacing:.22em;
    text-transform:uppercase;
    color:rgba(255,255,255,0.5);
    font-weight:400;
    white-space:pre-line;
    line-height:1.9;
  }

  /* Scroll cue */
  .scroll-cue{
    display:inline-flex;
    align-items:center;
    margin-top:48px;
    opacity:0.45;
    transition:opacity 0.3s;
  }
  .scroll-cue:hover{opacity:0.8}
  .scroll-line{
    display:block;
    width:1px;
    height:56px;
    background:rgba(255,255,255,0.6);
    animation:scroll-bob 2.2s ease-in-out infinite;
    transform-origin:top;
  }
  @keyframes scroll-bob{
    0%,100%{transform:scaleY(1);opacity:0.4}
    50%{transform:scaleY(0.6);opacity:1}
  }

  /* Shared */
  .eyebrow{
    font-size:12px;
    letter-spacing:.32em;
    text-transform:uppercase;
    color:var(--moss);
    font-weight:500;
    margin-bottom:24px;
  }
  h1{
    font-size:clamp(40px, 7vw, 88px);
    line-height:1.02;
    font-weight:400;
    margin:0;
    letter-spacing:-0.025em;
    color:var(--ink);
    max-width:18ch;
  }
  .sub{
    margin-top:28px;
    font-size:13px;
    letter-spacing:.18em;
    text-transform:uppercase;
    color:var(--mute);
    font-weight:400;
    max-width:60ch;
  }

  @media(max-width:820px){
    .hero--fullbleed{min-height:75vh}
    .scroll-cue{display:none}
  }
  @media(prefers-reduced-motion:reduce){
    .hero-glow{animation:none}
    .scroll-line{animation:none}
  }
</style>

<script>
  // Subtle parallax on hero image
  const img = document.getElementById('hero-img') as HTMLImageElement | null;
  if (img && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const onScroll = () => {
      const y = window.scrollY;
      img.style.transform = `scale(1.04) translateY(${y * 0.18}px)`;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    });
  }
</script>
